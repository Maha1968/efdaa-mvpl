# Copy this file to .env.local and fill in values from your Supabase project dashboard.
# Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public URL for WhatsApp share links (set to your Vercel URL in production)
NEXT_PUBLIC_APP_URL=https://efdaa-mvpl.vercel.app

# Admin email — only this account can access /admin
ADMIN_EMAIL=your-email@example.com

# Service role key (Supabase → Project Settings → API → service_role).
# Required for Admin → Demo data load/reset. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
